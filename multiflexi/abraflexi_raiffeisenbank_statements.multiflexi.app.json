{
  "$schema": "https://raw.githubusercontent.com/VitexSoftware/php-vitexsoftware-multiflexi-core/refs/heads/main/multiflexi.app.schema.json",
  "schemaVersion": "3.2.1",
  "uuid": "ad1394f4-cf59-4523-a83c-020a779ccc2f",
  "name": {
    "en": "Raiffeisenbank Statement importer for AbraFlexi",
    "cs": "Importér výpisů Raiffeisenbank pro AbraFlexi"
  },
  "description": {
    "en": "Raiffeisen Bank Statements puller",
    "cs": "Stahovač výpisů Raiffeisenbank"
  },
  "requirements": ["AbraFlexi", "RaiffeisenBank"],
  "tags": ["RaiffeisenBank", "Statements"],
  "homepage": "https://github.com/VitexSoftware/abraflexi-raiffeisenbank",
  "image": "",
  "executable": "abraflexi-raiffeisenbank-statements",
  "environment": {
    "ABRAFLEXI_COMPANY": {
      "type": "string",
      "description": {
        "en": "Company code",
        "cs": "Kód společnosti"
      },
      "defval": "demo_de",
      "category": "API",
      "required": false
    },
    "ABRAFLEXI_LOGIN": {
      "type": "string",
      "description": {
        "en": "AbraFlexi Login",
        "cs": "Přihlášení do AbraFlexi"
      },
      "defval": "winstrom",
      "category": "API",
      "required": false
    },
    "ABRAFLEXI_PASSWORD": {
      "type": "password",
      "description": {
        "en": "AbraFlexi password",
        "cs": "Heslo do AbraFlexi"
      },
      "defval": "winstrom",
      "category": "API",
      "required": false
    },
    "ABRAFLEXI_URL": {
      "type": "string",
      "description": {
        "en": "AbraFlexi Server URI",
        "cs": "Adresa serveru AbraFlexi"
      },
      "defval": "https://demo.flexibee.eu:5434",
      "category": "API",
      "required": false
    },
    "ACCOUNT_NUMBER": {
      "type": "string",
      "description": {
        "en": "Bank Account Number",
        "cs": "Číslo bankovního účtu"
      },
      "defval": "",
      "category": "Other",
      "required": false
    },
    "BANKA+": {
      "type": "string",
      "description": {
        "en": "Num row for income",
        "cs": "Číslo řádku pro příjem"
      },
      "defval": "",
      "category": "Other",
      "required": false
    },
    "BANKA-": {
      "type": "string",
      "description": {
        "en": "Num row for epense",
        "cs": "Číslo řádku pro výdaj"
      },
      "defval": "",
      "category": "Other",
      "required": false
    },
    "CERT_FILE": {
      "type": "file-path",
      "description": {
        "en": "Certificate file",
        "cs": "Soubor certifikátu"
      },
      "defval": "",
      "category": "Other",
      "required": false
    },
    "CERT_PASS": {
      "type": "password",
      "description": {
        "en": "Certificate password",
        "cs": "Heslo certifikátu"
      },
      "defval": "",
      "category": "Other",
      "required": false
    },
    "IMPORT_SCOPE": {
      "type": "string",
      "description": {
        "en": "Time scope of transactions downloaded",
        "cs": "Časový rozsah stahovaných transakcí"
      },
      "defval": "yesterday",
      "category": "Other",
      "required": false
    },
    "STATEMENT_LINE": {
      "type": "set",
      "description": {
        "en": "Bank Statement line",
        "cs": "Řádek bankovního výpisu"
      },
      "defval": "ADDITIONAL",
      "hint": {
        "en": "MAIN",
        "cs": "MAIN"
      },
      "options": {
        "MAIN": "Main statement line",
        "ADDITIONAL": "Doplňkový řádek výpisu"
      },
      "category": "Other",
      "required": false
    },
    "STATEMENT_LANGUAGE": {
      "type": "set",
      "description": {
        "en": "Request Bank Statement in given language",
        "cs": "Vyžádat bankovní výpis v daném jazyce"
      },
      "defval": "en",
      "hint": {
        "en": "cs",
        "cs": "cs"
      },
      "options": {
        "cs": "Český jazyk",
        "en": "English"
      },
      "category": "Other",
      "required": false
    },
    "XIBMCLIENTID": {
      "type": "string",
      "description": {
        "en": "ClientID",
        "cs": "ID klienta"
      },
      "defval": "",
      "category": "Other",
      "required": false
    },
    "EASE_LOGGER": {
      "type": "string",
      "description": {
        "en": "write log messages using",
        "cs": "Zapisovat logovací zprávy pomocí"
      },
      "defval": "console|syslog",
      "required": false,
      "category": "Behavior"
    },
    "APP_DEBUG": {
      "type": "bool",
      "description": {
        "en": "Show debug messages",
        "cs": "Zobrazit ladicí zprávy"
      },
      "defval": false,
      "required": true,
      "category": "Behavior"
    },
    "RESULT_FILE": {
      "type": "string",
      "description": {
        "en": "write output json data to",
        "cs": "Zapsat výstupní json data do"
      },
      "defval": "env_report.json",
      "required": false,
      "category": "Other"
    }
  }
}
