      "type": "string",
      "description": "",
      "defval": "demo_de",
      "category": "API",
      "required": false
    },
    "ABRAFLEXI_LOGIN": {
      "type": "string",
      "description": {
        "en": "AbraFlexi Login",
        "cs": "Přihlášení do AbraFlexi"
      },
      "defval": "winstrom",
      "category": "API",
      "required": false
    },
    "ABRAFLEXI_PASSWORD": {
      "type": "password",
