      "defval": "https://demo.flexibee.eu:5434",
      "category": "API",
      "required": false
    },
    "ACCOUNT_NUMBER": {
      "type": "string",
      "description": {
        "en": "Bank Account Number",
        "cs": "Číslo bankovního účtu"
      },
      "defval": "",
      "category": "Other",
      "required": false
    },
    "CERT_FILE": {
      "type": "file-path",
      "description": {
        "en": "Certificate file",
        "cs": "Soubor certifikátu"
      },
      "defval": "",
      "category": "Other",
      "required": false
    },
    "CERT_PASS": {
      "type": "password",
      "description": {
        "en": "Certificate password",
        "cs": "Heslo certifikátu"
      },
      "defval": "",
      "category": "Other",
      "required": false
    },
    "IMPORT_SCOPE": {
      "type": "string",
      "description": {
        "en": "Time scope of transactions downloaded",
        "cs": "Časový rozsah stahovaných transakcí"
