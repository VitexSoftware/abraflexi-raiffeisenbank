        "en": "AbraFlexi password",
        "cs": "Heslo do AbraFlexi"
      },
      "defval": "winstrom",
      "category": "API",
      "required": false
    },
    "ABRAFLEXI_URL": {
      "type": "string",
      "description": {
        "en": "AbraFlexi Server URI",
